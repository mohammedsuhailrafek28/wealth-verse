# WealthVerse local development
# Demo mode is enabled by default in development when this is omitted.
WEALTHVERSE_DEMO_MODE=true
# Production safety: demo mode is blocked in production unless explicitly allowed.
WEALTHVERSE_ALLOW_DEMO_IN_PRODUCTION=false

# Persistence mode. Defaults to volatile in-memory. Optional local dev JSON mode:
# WEALTHVERSE_PERSISTENCE=json
WEALTHVERSE_PERSISTENCE=memory

# Logging. Set to debug only for local diagnostics.
WEALTHVERSE_LOG_LEVEL=info

# Optional in demo mode. Required when using a real MySQL database.
DATABASE_URL=mysql://user:password@localhost:3306/wealthverse

# Required in production. Optional in local demo mode.
JWT_SECRET=replace-with-a-long-random-secret

# Required only for Manus OAuth sign-in.
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=
OAUTH_SERVER_URL=

# Optional template services for storage, LLM, maps, voice, and image helpers.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# Optional admin mapping.
OWNER_OPEN_ID=
